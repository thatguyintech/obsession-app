# HTML shell — short TTL so deploys pick up new hashed asset URLs quickly
/
  Cache-Control: public, max-age=300, must-revalidate

/index.html
  Cache-Control: public, max-age=300, must-revalidate

# Vite fingerprinted bundles — safe to cache until filename changes
/assets/*
  Cache-Control: public, max-age=31536000, immutable

# Screenplay JSON — changes rarely; SWR serves stale while refreshing in background
/data/*
  Cache-Control: public, max-age=604800, stale-while-revalidate=2592000
